{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "@cognizone/a2": {
      "projectType": "library",
      "root": "projects/cognizone/a2",
      "sourceRoot": "projects/cognizone/a2/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-ng-packagr:build",
          "options": {
            "tsConfig": "projects/cognizone/a2/tsconfig.lib.json",
            "project": "projects/cognizone/a2/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/a2/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/a2/src/test.ts",
            "tsConfig": "projects/cognizone/a2/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/a2/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/cognizone/a2/tsconfig.lib.json",
              "projects/cognizone/a2/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "@cognizone/server-file-browser": {
      "projectType": "library",
      "root": "projects/cognizone/server-file-browser",
      "sourceRoot": "projects/cognizone/server-file-browser/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-ng-packagr:build",
          "options": {
            "tsConfig": "projects/cognizone/server-file-browser/tsconfig.lib.json",
            "project": "projects/cognizone/server-file-browser/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/server-file-browser/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/server-file-browser/src/test.ts",
            "tsConfig": "projects/cognizone/server-file-browser/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/server-file-browser/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/cognizone/server-file-browser/tsconfig.lib.json",
              "projects/cognizone/server-file-browser/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "@cognizone/sse": {
      "projectType": "library",
      "root": "projects/cognizone/sse",
      "sourceRoot": "projects/cognizone/sse/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/sse/tsconfig.lib.json",
            "project": "projects/cognizone/sse/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/sse/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/sse/src/test.ts",
            "tsConfig": "projects/cognizone/sse/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/sse/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/cognizone/sse/tsconfig.lib.json",
              "projects/cognizone/sse/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    }
  },
  "defaultProject": "@cognizone/a2",
  "cli": {
    "analytics": false
  }
}