{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "@cognizone/a2": {
      "projectType": "library",
      "root": "projects/cognizone/a2",
      "sourceRoot": "projects/cognizone/a2/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/a2/tsconfig.lib.json",
            "project": "projects/cognizone/a2/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/a2/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/a2/src/test.ts",
            "tsConfig": "projects/cognizone/a2/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/a2/karma.conf.js"
          }
        }
      }
    },
    "@cognizone/server-file-browser": {
      "projectType": "library",
      "root": "projects/cognizone/server-file-browser",
      "sourceRoot": "projects/cognizone/server-file-browser/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/server-file-browser/tsconfig.lib.json",
            "project": "projects/cognizone/server-file-browser/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/server-file-browser/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/server-file-browser/src/test.ts",
            "tsConfig": "projects/cognizone/server-file-browser/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/server-file-browser/karma.conf.js"
          }
        }
      }
    },
    "@cognizone/sse": {
      "projectType": "library",
      "root": "projects/cognizone/sse",
      "sourceRoot": "projects/cognizone/sse/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/sse/tsconfig.lib.json",
            "project": "projects/cognizone/sse/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/sse/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/cognizone/sse/src/test.ts",
            "tsConfig": "projects/cognizone/sse/tsconfig.spec.json",
            "karmaConfig": "projects/cognizone/sse/karma.conf.js"
          }
        }
      }
    },
    "@cognizone/esco-shared": {
      "projectType": "library",
      "root": "projects/cognizone/esco-shared",
      "sourceRoot": "projects/cognizone/esco-shared/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/esco-shared/tsconfig.lib.json",
            "project": "projects/cognizone/esco-shared/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/esco-shared/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/cognizone/esco-shared/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/cognizone/esco-shared/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    },
    "@cognizone/tree-browser": {
      "projectType": "library",
      "root": "projects/cognizone/tree-browser",
      "sourceRoot": "projects/cognizone/tree-browser/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/cognizone/tree-browser/tsconfig.lib.json",
            "project": "projects/cognizone/tree-browser/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/cognizone/tree-browser/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/cognizone/tree-browser/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/cognizone/tree-browser/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
