{
  "extends": "../../../tsconfig.prod.json",
  "compilerOptions": {
    "outDir": "../../../out-tsc/lib",
    "target": "es2022",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": []
  },
  "angularCompilerOptions": {
    "skipTemplateCodegen": true,
    "strictMetadataEmit": true,
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": true,
    "enableResourceInlining": true
  },
  "exclude": ["**/*.spec.ts"]
}
