{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "module": "es2020",
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2015",
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "@cognizone/a2": [
        "projects/cognizone/a2"
      ],
      "@cognizone/a2/*": [
        "projects/cognizone/a2/*"
      ],
      "@cognizone/server-file-browser": [
        "projects/cognizone/server-file-browser"
      ],
      "@cognizone/server-file-browser/*": [
        "projects/cognizone/server-file-browser/*"
      ],
      "@cognizone/sse": [
        "projects/cognizone/sse"
      ],
      "@cognizone/sse/*": [
        "projects/cognizone/sse/*"
      ]
    }
  },
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": true
  }
}
