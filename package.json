{
  "name": "ng-a2",
  "version": "2.3.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:build": "node tasks/start-lib-build.js",
    "start:sync": "node tasks/start-lib-sync.js",
    "build": "ng build",
    "build-all": "npm run build-libs",
    "build-libs": "rimraf dist/cognizone && run-s build:*",
    "build:a2-core": "ng build @cognizone/a2-core --configuration production",
    "build:esco-shared": "ng build @cognizone/esco-shared --configuration production",
    "build:sse": "ng build @cognizone/sse --configuration production",
    "build:tree-browser": "ng build @cognizone/tree-browser --configuration production",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watchAll",
    "test:coverage": "jest --runInBand --coverage",
    "test:coverage:watch": "jest --runInBand --coverage --watchAll",
    "lint": "ng lint",
    "release": "npm run test && semantic-release",
    "release:sync-versions": "node ./tasks/sync-versions.js",
    "prepare": "husky install",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.9",
    "@angular/cdk": "^20.2.11",
    "@angular/common": "^20.3.9",
    "@angular/compiler": "^20.3.9",
    "@angular/core": "^20.3.9",
    "@angular/forms": "^20.3.9",
    "@angular/material": "^20.2.11",
    "@angular/platform-browser": "^20.3.9",
    "@angular/platform-browser-dynamic": "^20.3.9",
    "@angular/router": "^20.3.9",
    "@cognizone/model-utils": "^7.0.0-beta.2",
    "@cognizone/ng-core": "^7.0.0-beta.2",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.9",
    "@angular-devkit/core": "^20.3.8",
    "@angular-eslint/builder": "20.5.1",
    "@angular-eslint/eslint-plugin": "20.5.1",
    "@angular-eslint/eslint-plugin-template": "20.5.1",
    "@angular-eslint/schematics": "20.5.1",
    "@angular-eslint/template-parser": "20.5.1",
    "@angular/build": "^20.3.8",
    "@angular/cli": "^20.3.8",
    "@angular/compiler-cli": "^20.3.9",
    "@angular/language-service": "^20.3.9",
    "@cognizone/eslint-config": "^7.0.0-beta.2",
    "@cognizone/prettier-config": "^7.0.0-beta.2",
    "@cypress/schematic": "^4.1.4",
    "@semantic-release/changelog": "^3.0.6",
    "@semantic-release/exec": "^3.3.8",
    "@semantic-release/git": "^7.0.18",
    "@types/jest": "^29.5.14",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "angular-eslint": "^20.5.1",
    "copyfiles": "^2.4.1",
    "cypress": "^15.6.0",
    "eslint": "8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "lint-staged": "^15.5.2",
    "ng-packagr": "^20.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^3.0.2",
    "rxjs": "~7.8.0",
    "semantic-release": "^19.0.3",
    "shelljs": "^0.8.5",
    "ts-node": "~7.0.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "@cognizone/eslint-config": {
      "eslint": "8.57.1"
    },
    "@semantic-release/changelog": "^3.0.6",
    "semantic-release": "^19.0.3"
  },
  "volta": {
    "node": "20.19.5",
    "npm": "10.9.4"
  },
  "prettier": "@cognizone/prettier-config",
  "lint-staged": {
    "*.{js,css,scss,json,md,html,ts}": "prettier --write"
  }
}
