{
  "name": "a2",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:build": "node tasks/start-lib-build.js",
    "start:sync": "node tasks/start-lib-sync.js",
    "build": "ng build",
    "build-all": "npm run build-libs",
    "build-libs": "rimraf dist/cognizone && run-s build:*",
    "build:a2": "ng build @cognizone/a2 --configuration production",
    "build:esco-shared": "ng build @cognizone/esco-shared --configuration production",
    "build:server-file-browser": "ng build @cognizone/server-file-browser --configuration production",
    "build:sse": "ng build @cognizone/sse --configuration production",
    "build:tree-browser": "ng build @cognizone/tree-browser --configuration production",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watchAll",
    "lint": "ng lint",
    "release": "npm run test && semantic-release",
    "release:sync-versions": "node ./tasks/sync-versions.js",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.9",
    "@angular/cdk": "^20.2.11",
    "@angular/common": "^20.3.9",
    "@angular/compiler": "^20.3.9",
    "@angular/core": "^20.3.9",
    "@angular/forms": "^20.3.9",
    "@angular/material": "^20.2.11",
    "@angular/platform-browser": "^20.3.9",
    "@angular/platform-browser-dynamic": "^20.3.9",
    "@angular/router": "^20.3.9",
    "@cognizone/model-utils": "^3.14.1",
    "@cognizone/ng-core": "^3.14.1",
    "rxjs": "~6.6.3",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^20.3.8",
    "@angular/build": "^20.3.8",
    "@angular/cli": "^20.3.8",
    "@angular/compiler-cli": "^20.3.9",
    "@angular/language-service": "^20.3.9",
    "@cognizone/prettier-config": "^3.6.4",
    "@cognizone/tslint-config": "^2.0.0",
    "@semantic-release/changelog": "^3.0.6",
    "@semantic-release/exec": "^3.3.8",
    "@semantic-release/git": "^7.0.18",
    "@types/jest": "^29.5.12",
    "@types/node": "^12.11.1",
    "copyfiles": "^2.4.1",
    "husky": "^9.1.2",
    "jest": "^29.7.0",
    "jest-preset-angular": "^9.0.7",
    "lint-staged": "^15.2.7",
    "ng-packagr": "^20.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "rimraf": "^3.0.2",
    "semantic-release": "^19.0.3",
    "shelljs": "^0.8.5",
    "ts-node": "~7.0.0",
    "tslint": "~6.1.0",
    "typescript": "~5.9.3"
  },
  "volta": {
    "node": "20.19.5",
    "npm": "10.9.4"
  },
  "prettier": "@cognizone/prettier-config",
  "lint-staged": {
    "*.{js,css,scss,json,md,html,ts}": "prettier --write"
  }
}
